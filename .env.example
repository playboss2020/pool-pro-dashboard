VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_POOL_DEVICE_ID=pool-hub-001

# MVP fast-control path: browser publishes directly to HiveMQ over secure WebSocket.
# Use a restricted MQTT user that can only publish this device command topic.
VITE_MQTT_DIRECT_ENABLED=false
VITE_MQTT_WS_URL=wss://your-hivemq-host.s1.eu.hivemq.cloud:8884/mqtt
VITE_MQTT_USERNAME=your-publish-only-mqtt-user
VITE_MQTT_PASSWORD=your-mqtt-password
VITE_MQTT_COMMAND_TOPIC=pool/devices/pool-hub-001/commands
VITE_MQTT_STATE_TOPIC=pool/devices/pool-hub-001/state
